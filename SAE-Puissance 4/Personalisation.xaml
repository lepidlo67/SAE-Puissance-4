<Window x:Class="SAE_Puissance_4.Personalisation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SAE_Puissance_4"
        mc:Ignorable="d"
        Title="Personalisation" Height="750" Width="450" WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Personnalisation" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <StackPanel Grid.Row="1">

                <GroupBox Header="Contraste" Margin="0,0,0,15" Padding="10">
                    <StackPanel>
                        <Slider x:Name="SliderContraste" Minimum="0" Maximum="2" TickFrequency="1" IsSnapToTickEnabled="True" Value="0" ValueChanged="SliderContraste_ValueChanged"/>
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bas" Grid.Column="0" HorizontalAlignment="Left" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="Moyen" Grid.Column="1" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="Elevé" Grid.Column="2" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Police" Margin="0,0,0,15" Padding="10">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,5" FontWeight="Bold" FontSize="16"><Run Language="fr-fr" Text="Police d'ecriture"/><Run Text=" :"/></TextBlock>
                        <ComboBox x:Name="ComboPolice" Margin="0,0,0,15" SelectionChanged="ComboPolice_SelectionChanged">
                            <ComboBoxItem Content="Arial" IsSelected="True"/>
                            <ComboBoxItem Content="Comic Sans MS"/>
                            <ComboBoxItem Content="Verdana"/>
                            <ComboBoxItem Content="Times New Roman"/>
                        </ComboBox>

                        <TextBlock Text="Taille de la police :" Margin="0,0,0,5" FontWeight="Bold" FontSize="16"/>
                        <Slider x:Name="SliderTaillePolice" Minimum="12" Maximum="30" Value="16" TickFrequency="2" IsSnapToTickEnabled="True" ValueChanged="SliderTaillePolice_ValueChanged"/>
                        <TextBlock x:Name="LabelExemplePolice" Text="Exemple" HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="16"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Aperçu des jetons" Margin="0,0,0,15" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Joueur 1" HorizontalAlignment="Center" Margin="0,0,0,5" FontWeight="Bold" FontSize="16"/>
                            <Ellipse x:Name="PreviewJ1" Width="50" Height="50" Fill="Red" Stroke="Black" StrokeThickness="2"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Joueur 2" HorizontalAlignment="Center" Margin="0,0,0,5" FontWeight="Bold" FontSize="16"/>
                            <Ellipse x:Name="PreviewJ2" Width="50" Height="50" Fill="Yellow" Stroke="Black" StrokeThickness="2"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Couleurs des Jetons" Margin="0,0,0,15" Padding="10">
                    <StackPanel>
                        <TextBlock FontSize="16" Margin="0,0,0,10" FontWeight="Bold"><Run Language="fr-fr" Text="Choisissez"/><Run Text=" une couleur pour le joueur actif :"/></TextBlock>

                        <Grid HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Background="Red" Width="40" Height="40" Margin="5" Click="Color_Click" Grid.Row="0" Grid.Column="0"/>
                            <Button Background="Yellow" Width="40" Height="40" Margin="5" Click="Color_Click" Grid.Row="0" Grid.Column="1"/>
                            <Button Background="Blue" Width="40" Height="40" Margin="5" Click="Color_Click" Grid.Row="0" Grid.Column="2"/>
                            <Button Background="Green" Width="40" Height="40" Margin="5" Click="Color_Click" Grid.Row="0" Grid.Column="3"/>

                            <Button Background="Orange" Width="40" Height="40" Margin="5" Click="Color_Click" Grid.Row="1" Grid.Column="0"/>
                            <Button Background="Purple" Width="40" Height="40" Margin="5" Click="Color_Click" Grid.Row="1" Grid.Column="1"/>
                            <Button Background="Pink" Width="40" Height="40" Margin="5" Click="Color_Click" Grid.Row="1" Grid.Column="2"/>
                            <Button Background="Cyan" Width="40" Height="40" Margin="5" Click="Color_Click" Grid.Row="1" Grid.Column="3"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <RadioButton x:Name="RadioJ1" Content="Joueur 1" IsChecked="True" Margin="0,0,20,0"/>
                            <RadioButton x:Name="RadioJ2" Content="Joueur 2"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <Button x:Name="BtnEnregistrer" Content="Enregistrer Modifications" Background="#2E8B57" Foreground="White" Height="45" FontSize="16" Margin="0,0,0,10" Click="BtnEnregistrer_Click"/>
                <Button x:Name="BtnReinitialiser" Content="Réinitialiser par défaut" Background="#DC143C" Foreground="White" Height="45" FontSize="16" Click="BtnReinitialiser_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>