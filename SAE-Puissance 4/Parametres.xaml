<Window x:Class="SAE_Puissance_4.Parametres"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SAE_Puissance_4"
        mc:Ignorable="d"
        Title="Paramètres" Height="720" Width="420" WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20" Background="White" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="Paramètres" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <StackPanel Grid.Row="1">
                <Border BorderBrush="Black" BorderThickness="1.5" CornerRadius="8" Margin="0,0,0,18" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Mode de jeu" FontSize="12" Foreground="Gray" Margin="0,-25,0,10" Background="White" HorizontalAlignment="Left" Padding="5,0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnVsAmi" Content="👤 Vs Ami" Grid.Column="0" Margin="5" Height="40" Background="Black" Foreground="White" BorderBrush="Black" BorderThickness="2" Click="BtnVsAmi_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="BtnVsRobot" Content="🤖 Vs Robot" Grid.Column="1" Margin="5" Height="40" Background="White" Foreground="Black" BorderBrush="Black" BorderThickness="2" Click="BtnVsRobot_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="PanelDifficulte" Visibility="Collapsed" BorderBrush="Black" BorderThickness="1.5" CornerRadius="8" Margin="0,0,0,18" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Choix difficulté Robot" FontSize="12" Foreground="Gray" Margin="0,-25,0,10" Background="White" HorizontalAlignment="Left" Padding="5,0"/>
                        <Slider x:Name="SliderDifficulte" Minimum="0" Maximum="2" TickFrequency="1" IsSnapToTickEnabled="True" Margin="10,10,10,0"/>
                        <Grid Margin="10,5,10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Facile" Grid.Column="0" HorizontalAlignment="Left" FontSize="11"/>
                            <TextBlock Text="Moyen" Grid.Column="1" HorizontalAlignment="Center" FontSize="11"/>
                            <TextBlock Text="Difficile" Grid.Column="2" HorizontalAlignment="Right" FontSize="11"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border BorderBrush="Black" BorderThickness="1.5" CornerRadius="8" Margin="0,0,0,18" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Modifications Grille" FontSize="12" Foreground="Gray" Margin="0,-25,0,10" Background="White" HorizontalAlignment="Left" Padding="5,0"/>

                        <Grid Margin="0,5">
                            <TextBlock Text="Taille Grille" FontSize="16" VerticalAlignment="Center" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Colonnes" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="TxtColonnes" Text="7" Width="40" TextAlignment="Center" BorderBrush="Black" BorderThickness="1"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Lignes" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="TxtLignes" Text="6" Width="40" TextAlignment="Center" BorderBrush="Black" BorderThickness="1"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,15,0,5">
                            <TextBlock Text="Nombre de&#x0a;jetons à aligner" FontSize="16" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="TxtJetons" Text="4" Width="40" Height="25" TextAlignment="Center" HorizontalAlignment="Right" BorderBrush="Black" BorderThickness="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border BorderBrush="Black" BorderThickness="1.5" CornerRadius="8" Margin="0,0,0,18" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Options Supplémentaires" FontSize="12" Foreground="Gray" Margin="0,-25,0,10" Background="White" HorizontalAlignment="Left" Padding="5,0"/>

                        <Grid Margin="0,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Mode Challenge" FontSize="16" VerticalAlignment="Center" FontWeight="Bold"/>
                                <Button Content="ⓘ" Background="Transparent" BorderThickness="0" FontSize="16" Margin="5,0,0,0" Cursor="Hand" Click="BtnInfo_Click"/>
                            </StackPanel>
                            <CheckBox x:Name="TglChallenge" HorizontalAlignment="Left" Margin="314,0,0,0" VerticalAlignment="Center" RenderTransformOrigin="-0.444,0.519" />
                        </Grid>

                        <Grid Margin="0,15,0,5">
                            <TextBlock Text="Activer Chronomètre" FontSize="16" VerticalAlignment="Center" FontWeight="Bold"/>
                            <CheckBox x:Name="TglChrono" HorizontalAlignment="Left" Margin="314,6,0,0" VerticalAlignment="Top" IsChecked="False"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="PopupInfo" Background="#FFF9C4" BorderBrush="Black" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,15" Visibility="Collapsed">
                    <Grid>
                        <Button Content="X" Foreground="Red" Background="Transparent" BorderThickness="0" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-5,0" Click="BtnCloseInfo_Click"/>
                        <TextBlock Text="Lance plusieurs parties d'affilée&#x0a;avec le même adversaire" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,10,0,0"/>
                    </Grid>
                </Border>

            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <Button x:Name="BtnEnregistrer" Content="Enregistrer Modifications" Background="#2E8B57" Foreground="White" FontSize="16" Height="45" BorderBrush="Black" BorderThickness="1" Margin="0,0,0,10" Click="BtnEnregistrer_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="BtnReinitialiser" Content="Renitialiser" Background="#DC143C" Foreground="White" FontSize="16" Height="45" BorderBrush="Black" BorderThickness="1" Click="BtnReinitialiser_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>